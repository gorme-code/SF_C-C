<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>School_Year__c</fullName>
    <description>Groups YTD calculations across the July 1 cutover. Returns the spring calendar year of the school year.</description>
    <externalId>false</externalId>
    <formula>TEXT(IF(MONTH(Closure_Date__c) &gt;= 7, YEAR(Closure_Date__c) + 1, YEAR(Closure_Date__c)))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>School Year</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
