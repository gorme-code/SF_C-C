<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Tier__c</fullName>
    <description>Statutory tier derived from Total_Missed_Days__c (thresholds 3/6/9).</description>
    <externalId>false</externalId>
    <formula>IF(Total_Missed_Days__c &lt;= 3, &apos;Tier 1&apos;, IF(Total_Missed_Days__c &lt;= 6, &apos;Tier 2&apos;, IF(Total_Missed_Days__c &lt;= 9, &apos;Tier 3&apos;, &apos;Tier 4&apos;)))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Tier</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
